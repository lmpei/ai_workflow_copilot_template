# Shared-edge product deployment scaffold only.
# This repo is the dedicated product stack, not the root lmpai.online homepage.
APP_ENV_FILE=.env.weave.example
APP_ENV=staging

POSTGRES_DB=ai_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql+psycopg://postgres:replace_me@db:5432/ai_workflow
REDIS_URL=redis://redis:6379/0

AUTH_SECRET_KEY=replace_me
OPENAI_API_KEY=replace_me

CHAT_PROVIDER=qwen
CHAT_API_KEY=replace_me
CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen-plus

EVAL_PROVIDER=qwen
EVAL_API_KEY=replace_me
EVAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_MODEL=qwen-plus

EMBEDDING_PROVIDER=qwen
EMBEDDING_API_KEY=replace_me
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION_NAME=workspace_documents

NEXT_PUBLIC_MARKETING_SITE_URL=https://lmpai.online
NEXT_PUBLIC_API_BASE_URL=https://api.lmpai.online/api/v1
INTERNAL_API_BASE_URL=http://server:8000/api/v1

PUBLIC_WEB_URL=https://weave.lmpai.online
PUBLIC_WEB_HOST=weave.lmpai.online
PUBLIC_API_HOST=api.lmpai.online
CORS_ORIGINS=https://weave.lmpai.online

WEAVE_WEB_BIND_PORT=3001
WEAVE_API_BIND_PORT=8001

PUBLIC_DEMO_MODE=true
PUBLIC_DEMO_REGISTRATION_ENABLED=true
PUBLIC_DEMO_MAX_WORKSPACES_PER_USER=3
PUBLIC_DEMO_MAX_DOCUMENTS_PER_WORKSPACE=12
PUBLIC_DEMO_MAX_TASKS_PER_WORKSPACE=30
PUBLIC_DEMO_MAX_UPLOAD_BYTES=5242880
