# Local Docker Compose scaffold only.
# Replace secrets before startup, and override service URLs for shared dev or staging environments.
APP_ENV_FILE=.env
APP_ENV=local
POSTGRES_DB=ai_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_workflow
REDIS_URL=redis://redis:6379/0
# Replace before startup with a unique random secret used to sign auth tokens.
AUTH_SECRET_KEY=replace_me
# Replace any provider keys you actually plan to use. Do not keep replace_me in a shared environment.
OPENAI_API_KEY=replace_me
CHAT_PROVIDER=qwen
CHAT_API_KEY=replace_me
CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen-plus
EVAL_PROVIDER=qwen
EVAL_API_KEY=replace_me
EVAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_MODEL=qwen-plus
EMBEDDING_PROVIDER=qwen
EMBEDDING_API_KEY=replace_me
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
CHROMA_URL=http://chroma:8000
CHROMA_COLLECTION_NAME=workspace_documents
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
INTERNAL_API_BASE_URL=http://server:8000/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_DEMO_MODE=false
PUBLIC_DEMO_REGISTRATION_ENABLED=true
# Optional helper-only override for Stage B staging smoke checks or rehearsal handoff.
# STAGING_WEB_URL=https://staging.example.com
# Optional helper-only override for the public demo smoke path.
# PUBLIC_WEB_URL=http://localhost:3000
